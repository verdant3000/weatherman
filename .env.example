# Brooks WX Monitor — Environment Variables
# In Railway: set these in your service's Variables tab

# ── DATABASE ─────────────────────────────────────────────────────────────
# Railway injects this automatically when you add a Postgres service
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── WEATHER UNDERGROUND ──────────────────────────────────────────────────
# Free for PWS contributors: wunderground.com → My Profile → API Keys
WU_API_KEY=your_wu_api_key_here

# ── EMAIL DIGEST ─────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
DIGEST_TO=sean@gofieldtrip.ca

# ── APP ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
APP_URL=https://your-app.up.railway.app

# ── SCREENSHOTS (Railway Volume) ──────────────────────────────────────────
# Mount a Railway volume at /app/screenshots, then set:
SCREENSHOTS_DIR=/app/screenshots

# ── HOBOLINK (Sea to Sky Gondola — pending) ───────────────────────────────
HOBOLINK_TOKEN=stub_pending_credentials
HOBOLINK_LOGGER_ID=stub_pending_id

# ── OPTIONAL ─────────────────────────────────────────────────────────────
# Camera cron — default is 9am PT (16:00 UTC). Cron syntax, UTC.
CAMERA_CRON=0 16 * * *
